{
  "name": "marketplace/backend-phase1",
  "description": "Laravel 12 Phase 1 backend scaffold for food delivery marketplace.",
  "type": "project",
  "require": {
    "php": "^8.3",
    "laravel/framework": "^12.0",
    "laravel/sanctum": "^4.0",
    "laravel/reverb": "^1.0",
    "spatie/laravel-permission": "^6.0",
    "predis/predis": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "backend/app/",
      "Database\\Seeders\\": "backend/database/seeders/",
      "Database\\Factories\\": "backend/database/factories/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  }
}
